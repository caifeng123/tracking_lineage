{
  "name": "tracking-lineage-monorepo",
  "private": true,
  "scripts": {
    "build":          "pnpm -r build",
    "build:core":     "pnpm --filter @tracking-lineage/core build",
    "build:server":   "pnpm --filter @tracking-lineage/server build",
    "build:web":      "pnpm --filter @tracking-lineage/web build",

    "dev":            "pnpm --filter @tracking-lineage/server dev",
    "dev:web":        "pnpm --filter @tracking-lineage/web dev",
    "dev:cli":        "pnpm --filter @tracking-lineage/core dev:cli",

    "start":          "pnpm --filter @tracking-lineage/server start",
    "start:web":      "pnpm --filter @tracking-lineage/web start",

    "test":           "pnpm --filter @tracking-lineage/core test",

    "pack:web":       "bash scripts/build-web.sh",
    "pack:server":    "bash scripts/build-server.sh"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18"
  }
}
