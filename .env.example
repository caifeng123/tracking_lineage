# ==================== LLM ====================
# LLMClient 根据 base_url 自动判断接口格式:
#   - 包含 /messages → Anthropic Messages API（流式 SSE）
#   - 其它           → OpenAI Chat Completions API
#
# 请填写完整的接口地址，不会自动拼接路径:
#   Anthropic 示例: https://llmbox.bytedance.net/v1/messages
#   OpenAI   示例: https://api.openai.com/v1/chat/completions
LLM_BASE_URL=https://llmbox.bytedance.net/v1/messages
LLM_API_KEY=
LLM_MODEL=glm-5

# ==================== Claude Agent ====================
AGENT_MODEL=
ANTHROPIC_BASE_URL=http://127.0.0.1:3456
ANTHROPIC_AUTH_TOKEN=1

# ==================== App ====================
BUSINESS_KEY=unknown
TARGET_DIR=
RESULT_DIR=

# ==================== Concurrency ====================
GRAPH_CONCURRENCY=5
LLM_CONCURRENCY=10
AGENT_CONCURRENCY=10
MAX_RETRIES=3
